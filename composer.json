{
    "name": "velt/ui",
    "description": "Declarative UI components and renderers for the Velt framework.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Jules MUKADI",
            "email": "julesmukadi.dev@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "Velt\\Ui\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "require-dev": {
        "phpunit/phpunit": "11.5.x-dev",
        "phpstan/phpstan": "2.2.x-dev",
        "friendsofphp/php-cs-fixer": "dev-master",
        "symfony/var-dumper": "7.4.x-dev"
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "fix": "php-cs-fixer fix"
    }
}
